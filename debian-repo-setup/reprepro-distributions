# Dockershelf APT repository — reprepro distributions
#
# Node.js packages use the same codenames as Python packages. If the droplet is
# already configured for python-pipeline, no change is required.
#
# Install on the DigitalOcean droplet:
#   sudo mkdir -p /var/www/debian/conf
#   sudo cp reprepro-distributions /var/www/debian/conf/distributions
#   sudo chown -R "$USER":"$USER" /var/www/debian
#
# Replace SIGNWITH_KEY_ID with your GPG key id (gpg --list-keys --keyid-format long).

