# Copy to config.env and adjust before building or publishing.
#
#   cp config.env.example config.env

# GitHub org for node* clone URLs (falls back to local seed template).
DOCKERSHELF_GITHUB_ORG=Dockershelf

# Docker image namespace for Debian builder containers (codename appended).
DOCKERSHELF_BUILDER_IMAGE=ghcr.io/dockershelf/dockershelf-node-builder

# Tools image for meta-gbp / build (gbp, dch, dpkg-parsechangelog).
DOCKERSHELF_TOOLS_IMAGE=ghcr.io/dockershelf/dockershelf-node-builder/tools

# Debian suites to generate builder images for (space-separated codenames).
DOCKERSHELF_SUITES=trixie unstable

# Default Node major for Dockerfile generation (debiandirs/control source).
DOCKERSHELF_REFERENCE_NODE=22

# Debian maintainer identity for debuild / changelog (optional).
# Leave unset to use `git config user.name` and `git config user.email`.
# DEBFULLNAME="Luis Alejandro Martínez Faneyth"
# DEBEMAIL=luis@luisalejandro.org

# DigitalOcean droplet — APT repository publish target (shared with Python packages).
DOCKERSHELF_DEPLOY_HOST=apt.luisalejandro.org
DOCKERSHELF_DEPLOY_USER=deploy
DOCKERSHELF_DEPLOY_DIR=/var/www/debian
DOCKERSHELF_DEPLOY_INCOMING=/var/www/debian/incoming

# Public APT base URL (used in docs and node/build-image.sh integration).
DOCKERSHELF_APT_URL=https://apt.luisalejandro.org/dockershelf
